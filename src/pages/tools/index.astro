---
import Base from '../../layouts/Base.astro';

const sections = [
  {
    title: 'Design web',
    items: [
      { name: 'Figma', note: 'UI and systems.', href: 'https://www.figma.com/' },
      { name: 'Webflow', note: 'Client sites.', href: 'https://webflow.com/' },
      { name: 'Dinky', note: 'My app.', href: 'https://dinkyfiles.com/' },
    ],
  },
  {
    title: 'Agentic coding',
    items: [
      {
        name: 'Claude Desktop App',
        note: 'Daily driver.',
        href: 'https://claude.com/download',
      },
      { name: 'Cursor', note: 'Focused editing.', href: 'https://cursor.com/' },
    ],
  },
  {
    title: 'Writing',
    items: [
      { name: 'iA Writer', note: 'Drafts.', href: 'https://ia.net/writer' },
      { name: 'HEY', note: 'Email.', href: 'https://www.hey.com/' },
    ],
  },
  {
    title: 'Infra',
    items: [
      { name: 'GitHub', note: 'Code.', href: 'https://github.com/' },
      { name: 'Fathom', note: 'Analytics.', href: 'https://usefathom.com/' },
      { name: 'Netlify', note: 'Deploys.', href: 'https://www.netlify.com/' },
    ],
  },
  {
    title: 'Hardware',
    items: [
      {
        name: 'MacBook Air (M2, 2022)',
        note: '24 GB memory.',
        href: 'https://www.apple.com/macbook-air/',
      },
    ],
  },
];
---
<Base title="Tools — Derek Castelli" description="Tools Derek reaches for daily.">
  <article class="prose">
    <h1>Tools</h1>
    <p style="color: var(--fg-soft);">What I use to design, build, write, and ship.</p>

    {sections.map((section) => (
      <>
        <h2 class="section-title">/ {section.title.toLowerCase().replace(/\s+/g, '-')}</h2>
        <ul class="entries tools-list">
          {section.items.map((item) => (
            <li>
              {item.href ? (
                <a
                  class="entry-link"
                  href={item.href}
                  target="_blank"
                  rel="noopener"
                >
                  <span class="entry-title">{item.name}</span>
                  <span class="entry-meta" style="align-self: center;">{item.note}</span>
                </a>
              ) : (
                <>
                  <span class="entry-title">{item.name}</span>
                  <span class="entry-meta" style="align-self: center;">{item.note}</span>
                </>
              )}
            </li>
          ))}
        </ul>
      </>
    ))}
  </article>
</Base>
