---
import Base from '../../layouts/Base.astro';
const sections = [
  {
    title: 'Development',
    items: [
      { name: 'IntelliJ IDEA', note: 'Primary IDE.', href: 'https://www.jetbrains.com/idea/' },
      { name: 'VS Code', note: 'Lightweight editing.', href: 'https://code.visualstudio.com/' },
      { name: 'GitHub Copilot', note: 'AI pair programmer.', href: 'https://github.com/features/copilot' },
      { name: 'Termius', note: 'SSH client.', href: 'https://termius.com/' },
      { name: 'DBeaver', note: 'Database management.', href: 'https://dbeaver.io/' },
    ],
  },
  {
    title: 'Infra & Cloud',
    items: [
      { name: 'GitHub', note: 'Code and CI/CD.', href: 'https://github.com/' },
      { name: 'AWS', note: 'Cloud infrastructure.', href: 'https://aws.amazon.com/' },
      { name: 'Azure', note: 'Cloud services.', href: 'https://azure.microsoft.com/' },
      { name: 'Cloudflare', note: 'DNS and security.', href: 'https://www.cloudflare.com/' },
    ],
  },
  {
    title: 'Productivity',
    items: [
      { name: 'Raycast', note: 'Launcher and shortcuts.', href: 'https://www.raycast.com/' },
      { name: 'Obsidian', note: 'Notes and knowledge base.', href: 'https://obsidian.md/' },
      { name: 'Outlook', note: 'Email.', href: 'https://www.microsoft.com/en-us/microsoft-365/outlook/' },
      { name: 'MS Project', note: 'Project planning.', href: 'https://www.microsoft.com/en-us/microsoft-365/project/' },
      { name: 'Slack', note: 'Team communication.', href: 'https://slack.com/' },
      { name: 'Odoo', note: 'Business management.', href: 'https://www.odoo.com/' },
    ],
  },
  {
    title: 'Hardware',
    items: [
      { name: 'Mac Mini (M1)', note: 'Daily driver.', href: 'https://www.apple.com/mac-mini/' },
      { name: 'AOC 24" Monitor', note: 'Primary display.', href: 'https://www.aoc.com/' },
    ],
  },
];
---
<Base title="Tools — Wiran Larbi" description="Tools Larbi reaches for daily.">
  <article class="prose">
    <h1>Tools</h1>
    <p style="color: var(--fg-soft);">What I use to communicate, build, write, and ship.</p>

    {sections.map((section) => (
      <>
        <h2 class="section-title">/ {section.title.toLowerCase().replace(/\s+/g, '-')}</h2>
        <ul class="entries tools-list">
          {section.items.map((item) => (
            <li>
              {item.href ? (
                <a
                  class="entry-link"
                  href={item.href}
                  target="_blank"
                  rel="noopener"
                >
                  <span class="entry-title">{item.name}</span>
                  <span class="entry-meta" style="align-self: center;">{item.note}</span>
                </a>
              ) : (
                <>
                  <span class="entry-title">{item.name}</span>
                  <span class="entry-meta" style="align-self: center;">{item.note}</span>
                </>
              )}
            </li>
          ))}
        </ul>
      </>
    ))}
  </article>
</Base>
