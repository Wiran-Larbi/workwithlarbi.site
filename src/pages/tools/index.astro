---
import Base from '../../layouts/Base.astro';

const sections = [
  {
    title: 'Design web',
    items: [
      ['Figma', 'UI and systems.'],
      ['Webflow', 'Client sites.'],
      ['Dinky', 'My app.'],
    ],
  },
  {
    title: 'Agentic coding',
    items: [
      ['Claude Code', 'Daily driver.'],
      ['Cursor', 'Focused editing.'],
    ],
  },
  {
    title: 'Writing',
    items: [
      ['iA Writer', 'Drafts.'],
      ['HEY', 'Email.'],
    ],
  },
  {
    title: 'Infra',
    items: [
      ['GitHub', 'Code.'],
      ['Fathom', 'Analytics.'],
      ['Netlify', 'Deploys.'],
    ],
  },
  {
    title: 'Hardware',
    items: [
      [
        'MacBook Air (M2, 2022)',
        '24 GB memory · macOS Tahoe 26.3.1 (a).',
      ],
    ],
  },
];
---
<Base title="Tools — Derek Castelli" description="Tools Derek reaches for daily.">
  <article class="prose">
    <h1>Tools</h1>
    <p style="color: var(--fg-soft);">What I use to design, build, write, and ship.</p>

    {sections.map((section) => (
      <>
        <h2 class="section-title">/ {section.title.toLowerCase().replace(/\s+/g, '-')}</h2>
        <ul class="entries">
          {section.items.map(([name, note]) => (
            <li style="grid-template-columns: 160px 1fr;">
              <span class="entry-title" style="font-weight: 500;">{name}</span>
              <span class="entry-meta" style="align-self: center;">{note}</span>
            </li>
          ))}
        </ul>
      </>
    ))}
  </article>
</Base>
