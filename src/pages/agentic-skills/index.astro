---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('agenticSkills', ({ data }: any) => !data.draft)).sort(
  (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---
<Base title="Agentic Skills — Wiran Larbi" description="AI agents and agentic workflows built by Wiran Larbi.">
  <h1>Agentic Skills</h1>
  <p style="color: var(--fg-soft); max-width: var(--max-prose);">
    AI agents and agentic workflows I've built to solve real-world problems. Each agent demonstrates practical applications of AI in software development and business processes.
  </p>

  {entries.length > 0 ? (
    <ul class="entries">
      {entries.map((entry: any) => (
        <li>
          <a href={`/agentic-skills/${entry.slug}/`} class="entry-link">
            <span class="entry-date">
              {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </span>
            <span class="entry-content">
              <span class="entry-title">{entry.data.title}</span>
              <span class="entry-meta">{entry.data.description}</span>
              {entry.data.deployedAt && (
                <span class="entry-meta" style="margin-top: 4px;">
                  Deployed at: {entry.data.deployedAt}
                </span>
              )}
            </span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p style="color: var(--muted);">No agentic skills yet.</p>
  )}
</Base>
