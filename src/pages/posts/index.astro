---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';

const entries = (await getCollection('posts', ({ data }: any) => !data.draft)).sort(
  (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---
<Base title="Posts — Wiran Larbi" description="Writing on technology, business and latests projects by Wiran Larbi.">
  <h1>Posts</h1>
  <p style="color: var(--fg-soft); max-width: var(--max-prose);">
    Notes and essays on thoughts, tech, and latest projects. For experiences and shipped work, see{' '}
    <a href="/work/">Work</a>.
  </p>

  {entries.length > 0 ? (
    <PostList entries={entries} showYearHeaders={true} />
  ) : (
    <p style="color: var(--muted);">No posts yet.</p>
  )}
</Base>
