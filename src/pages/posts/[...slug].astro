---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { schemaPersonId } from '../../lib/schemaIds';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const siteOrigin = (Astro.site?.toString() ?? 'https://heyderekj.com/').replace(/\/$/, '');
const defaultDesc =
  'Agentic design engineer, still making websites full-time. Writing on faith and technology.';
const postDescription = post.data.description ?? defaultDesc;
const postPath = `/posts/${post.slug}/`;
const postUrl = new URL(postPath, `${siteOrigin}/`).toString();
const published = post.data.date.toISOString();
const postJsonLd = {
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: postDescription,
  datePublished: published,
  url: postUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  author: { '@type': 'Person', '@id': schemaPersonId(siteOrigin), name: 'Derek Castelli' },
  publisher: { '@type': 'Person', '@id': schemaPersonId(siteOrigin), name: 'Derek Castelli' },
  ...(post.data.tags?.length
    ? { keywords: post.data.tags.join(', ') }
    : {}),
};

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<Base
  title={`${post.data.title} — Derek Castelli`}
  description={postDescription}
  ogType="article"
  articlePublishedTime={published}
  jsonLd={postJsonLd}
  canonical={postUrl}
>
  <article class="prose">
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="meta">
        <time datetime={post.data.date.toISOString()}>{fmtDate(post.data.date)}</time>
        {post.data.tags && post.data.tags.length > 0 && (
          <span> · {post.data.tags.join(', ')}</span>
        )}
      </div>
    </header>
    <div class="post-content">
      <Content />
    </div>
    <p class="back-link">
      <a href="/posts/"><span class="arrow">&larr;</span> all posts</a>
    </p>
  </article>
</Base>
