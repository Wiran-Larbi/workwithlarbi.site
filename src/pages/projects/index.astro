---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectList from '../../components/ProjectList.astro';
import { projectStartTime } from '../../lib/projectStart';

const projects = await getCollection('projects');
const activeProjects = projects
  .filter((p) => p.data.status === 'active')
  .sort((a, b) => projectStartTime(b) - projectStartTime(a));
const pausedProjects = projects
  .filter((p) => p.data.status === 'paused')
  .sort((a, b) => projectStartTime(b) - projectStartTime(a));
const retiredProjects = projects
  .filter((p) => p.data.status === 'retired')
  .sort((a, b) => projectStartTime(a) - projectStartTime(b));
---
<Base title="Projects — Derek Castelli" description="Apps and sites built by Derek Castelli.">
  <h1>Projects</h1>
  <p style="color: var(--fg-soft); max-width: var(--max-prose);">
    Apps and experiments—design, code, and AI.
  </p>

  {activeProjects.length > 0 && <ProjectList projects={activeProjects} />}

  {pausedProjects.length > 0 && (
    <>
      <h2 class="projects-section-title" id="inactive">Inactive</h2>
      <p class="projects-section-lede">
        {`${pausedProjects.length} ${pausedProjects.length === 1 ? 'project' : 'projects'} that may continue.`}
      </p>
      <ProjectList projects={pausedProjects} variant="compact" startedOrder="desc" />
    </>
  )}

  {retiredProjects.length > 0 && (
    <>
      <h2 class="projects-section-title" id="retired">Retired</h2>
      <p class="projects-section-lede">
        {retiredProjects.length} past {retiredProjects.length === 1 ? 'project' : 'projects'} from the archive.
      </p>
      <ProjectList projects={retiredProjects} variant="compact" startedOrder="asc" />
    </>
  )}
</Base>

<style>
  .projects-section-title {
    font-size: var(--size-h2);
    font-weight: 600;
    margin-top: var(--space-4);
    margin-bottom: var(--space-1);
    scroll-margin-top: var(--space-3);
  }

  .projects-section-lede {
    margin: 0 0 var(--space-2);
    font-size: var(--size-meta);
    color: var(--fg-soft);
  }
</style>
