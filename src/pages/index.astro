---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostList from '../components/PostList.astro';
import FeaturedProjectGrid from '../components/FeaturedProjectGrid.astro';
import { projectStartTime } from '../lib/projectStart';
import NowHomeTicker from '../components/NowHomeTicker.astro';
import { schemaPersonId, schemaWebsiteId } from '../lib/schemaIds';
import GitHubActivity from '../components/GitHubActivity.astro';
import { fetchGitHubActivity } from '../lib/github';

const siteOrigin = (Astro.site?.toString() ?? 'https://heyderekj.com/').replace(/\/$/, '');
const defaultDesc =
  'Agentic design engineer, still making websites full-time. Writing on faith and technology.';
const homeJsonLd = [
  {
    '@type': 'WebSite',
    '@id': schemaWebsiteId(siteOrigin),
    url: `${siteOrigin}/`,
    name: 'Derek Castelli',
    description: defaultDesc,
    inLanguage: 'en-US',
    publisher: { '@id': schemaPersonId(siteOrigin) },
  },
  {
    '@type': 'Person',
    '@id': schemaPersonId(siteOrigin),
    name: 'Derek Castelli',
    url: siteOrigin,
    jobTitle: 'Agentic design engineer',
    sameAs: ['https://github.com/heyderekj', 'https://twitter.com/heyderekj'],
  },
];

const recentPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const recentWork = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const featuredProjects = allProjects
  .filter(({ data }) => data.featured)
  .sort((a, b) => projectStartTime(b) - projectStartTime(a));
const pausedProjects = allProjects.filter((p) => p.data.status === 'paused');
const retiredProjects = allProjects.filter((p) => p.data.status === 'retired');
const pausedCount = pausedProjects.length;
const retiredCount = retiredProjects.length;

const githubData = await fetchGitHubActivity();
---
<Base jsonLd={homeJsonLd}>
  <section class="intro">
    <p>
      An agentic design engineer and Christian making websites with{' '}
      <a href="https://kemdesign.co" rel="noopener noreferrer">Kem Design</a>, with apps on the side. I write about my life, faith, and tech, drawing on work in Apple Retail, design work for a church, and freelance work since 2020.
    </p>
    <p class="now-line">
      <NowHomeTicker />
    </p>
  </section>

  <h2 class="section-title"><a href="/posts/">/ posts</a></h2>
  {recentPosts.length > 0 ? (
    <PostList entries={recentPosts} />
  ) : (
    <p style="color: var(--muted);">No posts yet — adding soon.</p>
  )}

  <h2 class="section-title"><a href="/work/">/ work</a></h2>
  {recentWork.length > 0 ? (
    <PostList entries={recentWork} />
  ) : (
    <p style="color: var(--muted);">No work posts yet.</p>
  )}

  <h2 class="section-title"><a href="/projects/">/ projects</a></h2>
  <FeaturedProjectGrid projects={featuredProjects} />
  {(pausedCount > 0 || retiredCount > 0) && (
    <ul class="entries home-status-summaries">
      {pausedCount > 0 && (
        <li>
          <a href="/projects/#inactive" class="entry-link home-status-summary-link">
            <span class="home-status-summary-pill-wrap">
              <span class="card-status card-status--paused">inactive</span>
            </span>
            <span class="entry-title home-status-summary-title">
              {pausedCount} inactive {pausedCount === 1 ? 'project' : 'projects'}
            </span>
          </a>
        </li>
      )}
      {retiredCount > 0 && (
        <li>
          <a href="/projects/#retired" class="entry-link home-status-summary-link">
            <span class="home-status-summary-pill-wrap">
              <span class="card-status card-status--retired">retired</span>
            </span>
            <span class="entry-title home-status-summary-title">
              {retiredCount} retired {retiredCount === 1 ? 'project' : 'projects'}
            </span>
          </a>
        </li>
      )}
    </ul>
  )}

  <GitHubActivity data={githubData} />
</Base>

<style>
  .home-status-summaries {
    margin-top: var(--space-4);
  }

  :global(main.main) .home-status-summary-link {
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--space-2);
  }

  .home-status-summary-pill-wrap {
    display: inline-flex;
    align-items: center;
  }

  .home-status-summary-title {
    font-weight: 500;
    color: var(--muted-strong);
    font-variant-numeric: tabular-nums;
  }

  :global(main.main) .home-status-summary-link:hover .home-status-summary-title {
    color: var(--accent);
  }

  .card-status {
    flex-shrink: 0;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: var(--radius-pill);
    line-height: 1.2;
  }

  .card-status--paused {
    color: var(--muted-strong);
    background: rgba(234, 179, 8, 0.12);
    border: 1px solid rgba(234, 179, 8, 0.4);
  }

  .card-status--retired {
    color: var(--muted);
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid var(--border);
  }

  @media (prefers-color-scheme: dark) {
    .card-status--retired {
      background: rgba(255, 255, 255, 0.04);
    }
  }
</style>
