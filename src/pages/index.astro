---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostList from '../components/PostList.astro';
import FeaturedProjectGrid from '../components/FeaturedProjectGrid.astro';
import FeaturedWorkGrid from '../components/FeaturedWorkGrid.astro';
import { projectStartTime } from '../lib/projectStart';
import NowHomeTicker from '../components/NowHomeTicker.astro';
import { schemaPersonId, schemaWebsiteId } from '../lib/schemaIds';
import GitHubActivity from '../components/GitHubActivity.astro';
import { fetchGitHubActivity } from '../lib/github';

const siteOrigin = (Astro.site?.toString() ?? 'https://workwithlarbi.site/').replace(/\/$/, '');
const defaultDesc =
  'Agentic design engineer, still making websites full-time. Writing on faith and technology.';
const homeJsonLd = [
  {
    '@type': 'WebSite',
    '@id': schemaWebsiteId(siteOrigin),
    url: `${siteOrigin}/`,
    name: 'Wiran Larbi',
    description: defaultDesc,
    inLanguage: 'en-US',
    publisher: { '@id': schemaPersonId(siteOrigin) },
  },
  {
    '@type': 'Person',
    '@id': schemaPersonId(siteOrigin),
    name: 'Wiran Larbi',
    url: siteOrigin,
    jobTitle: 'Full Stack Software Engineer',
    sameAs: ['https://github.com/Wiran-Larbi', 'https://x.com/dotci0her'],
  },
];

const recentPosts = (await getCollection('posts', ({ data }: any) => !data.draft))
  .sort((a:any, b:any) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const recentCaseStudies = (await getCollection('caseStudies', ({ data }: any) => !data.draft))
  .sort((a:any, b:any) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const recentAgenticSkills = (await getCollection('agenticSkills', ({ data }: any) => !data.draft))
  .sort((a:any, b:any) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const highlightedWork = (await getCollection('work', ({ data }: any) => !data.draft && data.highlight)).sort(
  (a:any, b:any) => b.data.date.valueOf() - a.data.date.valueOf()
);
const homeHighlightedWork = highlightedWork.filter(({ slug }: any) => slug !== 'secoraprep-affiliate').slice(0, 2);

const allProjects = await getCollection('projects', ({ data }: any) => !data.draft);
const featuredProjects = allProjects
  .filter(({ data }: any) => data.featured)
  .sort((a: any, b: any) => projectStartTime(b) - projectStartTime(a));
const pausedProjects = allProjects.filter((p: any) => p.data.status === 'paused');
const retiredProjects = allProjects.filter((p: any) => p.data.status === 'retired');
const pausedCount = pausedProjects.length;
const retiredCount = retiredProjects.length;

const githubData = await fetchGitHubActivity();

const skills = [
  'Web Development',
  'CRM Integration',
  'ERP Development',
  'Mobile Development',
  'CI/CD Pipelines',
  'Database Management',
  'Cloud Architecture',
  'API Development',
  'DevOps',
  'Consulting',
];
---
<Base jsonLd={homeJsonLd}>
  <section class="intro">
    <p>
      Engineer by training. 
      Translator by instinct.
      <br class="simple-margin"/>

      I build full-stack applications with Java, Spring Boot, and React and I've spent years learning how to take that work and make it mean something in a boardroom. 

      <br class="simple-margin"/>

      I bridge the space between technical teams and business decisions, and I think that's where real impact happens.
      I work full-time and take on side projects in cloud and application development.
    </p>
    <p class="now-line">
      <NowHomeTicker />
    </p>
  </section>

  <div class="skills-section">
    <h2 class="skills-title">What I Can Help With</h2>
    <div class="skills-tags">
      {skills.map((skill) => (
        <span class="skill-tag">{skill}</span>
      ))}
    </div>
  </div>

  <h2 class="section-title"><a href="/work/">/ work</a></h2>
{homeHighlightedWork.length > 0 ? (
    <FeaturedWorkGrid work={homeHighlightedWork} />
  ) : (
    <p style="color: var(--muted);">No highlighted work posts yet.</p>
  )}

  <h2 class="section-title"><a href="/case-studies/">/ case studies</a></h2>
  {recentCaseStudies.length > 0 ? (
    <PostList entries={recentCaseStudies} />
  ) : (
    <p style="color: var(--muted);">No case studies yet — adding soon.</p>
  )}

  <h2 class="section-title"><a href="/posts/">/ posts</a></h2>
  {recentPosts.length > 0 ? (
    <PostList entries={recentPosts} />
  ) : (
    <p style="color: var(--muted);">No posts yet — adding soon.</p>
  )}

  <h2 class="section-title"><a href="/projects/">/ projects</a></h2>
  <FeaturedProjectGrid projects={featuredProjects} />
  {(pausedCount > 0 || retiredCount > 0) && (
    <ul class="entries home-status-summaries">
      {pausedCount > 0 && (
        <li>
          <a href="/projects/#inactive" class="entry-link home-status-summary-link">
            <span class="home-status-summary-pill-wrap">
              <span class="card-status card-status--paused">inactive</span>
            </span>
            <span class="entry-title home-status-summary-title">
              {pausedCount} inactive {pausedCount === 1 ? 'project' : 'projects'}
            </span>
          </a>
        </li>
      )}
      {retiredCount > 0 && (
        <li>
          <a href="/projects/#retired" class="entry-link home-status-summary-link">
            <span class="home-status-summary-pill-wrap">
              <span class="card-status card-status--retired">retired</span>
            </span>
            <span class="entry-title home-status-summary-title">
              {retiredCount} retired {retiredCount === 1 ? 'project' : 'projects'}
            </span>
          </a>
        </li>
      )}
    </ul>
  )}

  <h2 class="section-title"><a href="/agentic-skills/">/ agentic skills</a></h2>
  {recentAgenticSkills.length > 0 ? (
    <ul class="entries">
      {recentAgenticSkills.map((entry: any) => (
        <li>
          <a href={`/agentic-skills/${entry.slug}/`} class="entry-link">
            <span class="entry-date">
              {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </span>
            <span class="entry-title">{entry.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p style="color: var(--muted);">No agentic skills yet.</p>
  )}

  <GitHubActivity data={githubData} />
</Base>

<style>
  .skills-section {
    margin: var(--space-5) 0;
    padding: var(--space-4);
    background: var(--bg-elevated);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
  }

  .skills-title {
    font-size: var(--size-h2);
    font-weight: 600;
    margin: 0 0 var(--space-3);
    color: var(--fg);
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .skill-tag {
    display: inline-block;
    padding: 6px 14px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: var(--size-meta);
    font-weight: 500;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    transition: all 0.2s ease;
  }

  .skill-tag:hover {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  .home-status-summaries {
    margin-top: var(--space-4);
  }

  :global(main.main) .home-status-summary-link {
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--space-2);
  }

  .home-status-summary-pill-wrap {
    display: inline-flex;
    align-items: center;
  }

  .home-status-summary-title {
    font-weight: 500;
    color: var(--muted-strong);
    font-variant-numeric: tabular-nums;
  }

  :global(main.main) .home-status-summary-link:hover .home-status-summary-title {
    color: var(--accent);
  }

  .card-status {
    flex-shrink: 0;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: var(--radius-pill);
    line-height: 1.2;
  }

  .card-status--paused {
    color: var(--muted-strong);
    background: rgba(234, 179, 8, 0.12);
    border: 1px solid rgba(234, 179, 8, 0.4);
  }

  .card-status--retired {
    color: var(--muted);
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid var(--border);
  }

  .simple-margin {
    margin: 8px 0;
  }

  @media (prefers-color-scheme: dark) {
    .card-status--retired {
      background: rgba(255, 255, 255, 0.04);
    }
  }
</style>
