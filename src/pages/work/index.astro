---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';
import { postHasWorkTag } from '../../lib/postTags';

const posts = (await getCollection('posts', ({ data }) => !data.draft && postHasWorkTag(data)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base
  title="Work — Derek Castelli"
  description="Case studies and write-ups from client and shipped product work—Webflow builds, branding sites, and collaborations."
>
  <h1>Work</h1>
  <p style="color: var(--fg-soft); max-width: var(--max-prose);">
    Selected posts from shipped sites and collaborations. Also see the full <a href="/posts/">posts archive</a> and{' '}
    <a href="/projects/">projects</a>.
  </p>

  {posts.length > 0 ? (
    <PostList posts={posts} showYearHeaders={true} />
  ) : (
    <p style="color: var(--muted);">No work-tagged posts yet.</p>
  )}
</Base>
