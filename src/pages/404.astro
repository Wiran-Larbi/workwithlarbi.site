---
import Base from '../layouts/Base.astro';

const siteUrl = (Astro.site?.toString() ?? 'https://heyderekj.com').replace(/\/$/, '');
const canonical = `${siteUrl}/404/`;
const title = 'Page not found — Derek Castelli';
const description = 'This URL does not exist on heyderekj.com.';
---
<Base title={title} description={description} canonical={canonical} noindex>
  <article class="prose">
    <h1>Page not found</h1>
    <p style="color: var(--fg-soft);">
      This page isn’t here—maybe a broken link, a typo, or an old bookmark. Head back home or
      use the nav to find something that is.
    </p>
    <p>
      <a href="/">Back to the homepage</a>
    </p>
  </article>
</Base>
