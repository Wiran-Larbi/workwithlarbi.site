---
import { nowHomeTickerItems } from '../data/now';

const marqueeRepeat = [0, 1] as const;
const first = nowHomeTickerItems[0];
---

<span
  class="now-ticker"
  role="region"
  aria-label="Verse links on Bible.com — Proverbs 25:2 (NLT), Ephesians 2:10 (NIV), Hebrews 11:1 (NLT)"
>
  <a
    class="now-ticker__static now-ticker__verse"
    href={first.href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${first.verseLabel}, ${first.translationName} on Bible.com`}
  >
    {first.line}
  </a>
  <span class="now-marquee">
    <span class="now-marquee__track">
      {marqueeRepeat.map((_, repeatIndex) => (
        <span class="now-marquee__chunk" aria-hidden={repeatIndex === 1 ? 'true' : undefined}>
          {nowHomeTickerItems.map((item, i) => (
            <>
              {i > 0 && (
                <span class="now-marquee__sep" aria-hidden="true">
                  <i class="ph-bold ph-x" aria-hidden="true"></i>
                </span>
              )}
              <a
                class="now-ticker__verse"
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                tabindex={repeatIndex === 1 ? -1 : undefined}
                aria-label={`${item.verseLabel}, ${item.translationName} on Bible.com`}
              >
                {item.line}
              </a>
            </>
          ))}
        </span>
      ))}
    </span>
  </span>
</span>
