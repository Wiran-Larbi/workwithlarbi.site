---
import type { GitHubData } from '../lib/github';
import { relativeTimeFromIso } from '../lib/relativeTime';

interface Props {
  data: GitHubData;
}

const { data } = Astro.props;

function contributionLevel(count: number): number {
  if (count === 0) return 0;
  if (count <= 3) return 1;
  if (count <= 6) return 2;
  if (count <= 9) return 3;
  return 4;
}

const mostRecentPush = data.recentRepos.reduce<string | undefined>((latest, r) => {
  if (!latest) return r.pushedAt;
  return new Date(r.pushedAt) > new Date(latest) ? r.pushedAt : latest;
}, data.recentRepos[0]?.pushedAt);

/* Baked for SSR/SEO; wopr client recomputes from data-wopr-push-iso at view time. */
const lastCommitRel = relativeTimeFromIso(mostRecentPush);

const line1 = `> LAST COMMIT: ${lastCommitRel}`;
const line2 = `> ${data.totalContributions} COMMITS — PAST YEAR`;
const sortedRecentRepos = [...data.recentRepos].sort(
  (a, b) => new Date(b.pushedAt).getTime() - new Date(a.pushedAt).getTime()
);

function logLine(repo: GitHubData['recentRepos'][number]): string {
  const lang = repo.primaryLanguage?.name ?? '—';
  const repoName = repo.owner !== 'Wiran-Larbi' ? `${repo.owner}/${repo.name}` : repo.name;
  const desc = repo.description ? repo.description.replace(/\s+/g, ' ').slice(0, 48) : '';
  const tail = desc ? ` — ${desc}${repo.description && repo.description.length > 48 ? '…' : ''}` : '';
  return `> ${repoName} [${lang}]${tail}`;
}
---

<section class="wopr-section">
  <h2 class="section-title">/ activity</h2>

  <div class="wopr-terminal" data-wopr>
    <div class="wopr-lines">
      <div
        data-wopr-line={line1}
        data-wopr-delay="0"
        data-wopr-push-iso={mostRecentPush ?? ''}
      >
      </div>
      <div data-wopr-line={line2} data-wopr-delay="0"></div>
    </div>

    <div class="wopr-heatmap-clip">
      <div
        class="wopr-heatmap"
        data-wopr-heatmap
        role="img"
        aria-label={`GitHub contributions: ${data.totalContributions} in the past year`}
      >
        {data.weeks.map((week, wi) =>
          week.contributionDays.map((day) => (
            <div
              class="wopr-cell"
              style="--wopr-level: 0"
              data-real={contributionLevel(day.contributionCount)}
              data-week={wi}
              title={`${day.contributionCount} commit${day.contributionCount !== 1 ? 's' : ''} on ${day.date}`}
              aria-hidden="true"
            />
          ))
        )}
      </div>
    </div>

    <div class="wopr-log" data-wopr-log>
      {
        sortedRecentRepos.map((repo) => (
          <div class="wopr-log-entry" data-wopr-line={logLine(repo)} data-wopr-delay="0" />
        ))
      }
    </div>
  </div>
</section>

<script src="../client/wopr.ts"></script>
