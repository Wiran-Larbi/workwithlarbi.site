---
import type { GitHubData } from '../lib/github';

interface Props {
  data: GitHubData;
}

const { data } = Astro.props;

function contributionLevel(count: number): number {
  if (count === 0) return 0;
  if (count <= 3) return 1;
  if (count <= 6) return 2;
  if (count <= 9) return 3;
  return 4;
}

function relativeFromPush(iso: string | undefined): string {
  if (!iso) return 'UNKNOWN';
  const then = new Date(iso).getTime();
  if (Number.isNaN(then)) return 'UNKNOWN';
  const sec = Math.round((Date.now() - then) / 1000);
  if (sec < 45) return 'just now';
  const min = Math.floor(sec / 60);
  if (min < 60) return `${min} minute${min === 1 ? '' : 's'} ago`;
  const hr = Math.floor(min / 60);
  if (hr < 24) return `${hr} hour${hr === 1 ? '' : 's'} ago`;
  const day = Math.floor(hr / 24);
  if (day < 30) return `${day} day${day === 1 ? '' : 's'} ago`;
  const mo = Math.floor(day / 30);
  if (mo < 12) return `${mo} month${mo === 1 ? '' : 's'} ago`;
  const yr = Math.floor(day / 365);
  return `${yr} year${yr === 1 ? '' : 's'} ago`;
}

const mostRecentPush = data.recentRepos.reduce<string | undefined>((latest, r) => {
  if (!latest) return r.pushedAt;
  return new Date(r.pushedAt) > new Date(latest) ? r.pushedAt : latest;
}, data.recentRepos[0]?.pushedAt);

/* Relative time since latest activity on fetched public repos (pushedAt ≈ last push to default branch). */
const lastCommitRel = relativeFromPush(mostRecentPush);

const line1 = `> LAST COMMIT: ${lastCommitRel}`;
const line2 = `> ${data.totalContributions} COMMITS — PAST YEAR`;

function logLine(repo: GitHubData['recentRepos'][number]): string {
  const lang = repo.primaryLanguage?.name ?? '—';
  const desc = repo.description ? repo.description.replace(/\s+/g, ' ').slice(0, 48) : '';
  const tail = desc ? ` — ${desc}${repo.description && repo.description.length > 48 ? '…' : ''}` : '';
  return `> ${repo.name} [${lang}]${tail}`;
}
---

<section class="wopr-section">
  <h2 class="section-title">/ activity</h2>

  <div class="wopr-terminal" data-wopr>
    <div class="wopr-lines">
      <div data-wopr-line={line1} data-wopr-delay="0"></div>
      <div data-wopr-line={line2} data-wopr-delay="0"></div>
    </div>

    <div
      class="wopr-heatmap"
      data-wopr-heatmap
      style={`grid-template-columns: repeat(${Math.max(data.weeks.length, 1)}, 9px);`}
      role="img"
      aria-label={`GitHub contributions: ${data.totalContributions} in the past year`}
    >
      {
        data.weeks.map((week) =>
          week.contributionDays.map((day) => (
            <div
              class="wopr-cell"
              style={`--wopr-level: ${contributionLevel(day.contributionCount)}`}
              data-count={day.contributionCount}
              data-date={day.date}
              title={`${day.contributionCount} commit${day.contributionCount !== 1 ? 's' : ''} on ${day.date}`}
              aria-hidden="true"
            ></div>
          ))
        )
      }
    </div>

    <div class="wopr-log" data-wopr-log>
      {
        data.recentRepos.map((repo) => (
          <div class="wopr-log-entry" data-wopr-line={logLine(repo)} data-wopr-delay="0" />
        ))
      }
    </div>
  </div>
</section>

<script src="../client/wopr.ts"></script>
