---
import type { ListableEntry } from '../lib/postPaths';
import { entryHref } from '../lib/postPaths';

interface Props {
  entries: ListableEntry[];
  showYearHeaders?: boolean;
}

const { entries, showYearHeaders = false } = Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });

const fmtDateWithYear = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });

const groupedByYear = showYearHeaders
  ? entries.reduce<Record<string, ListableEntry[]>>((acc, post) => {
      const y = post.data.date.getFullYear().toString();
      (acc[y] ||= []).push(post);
      return acc;
    }, {})
  : null;

const years = groupedByYear
  ? Object.keys(groupedByYear).sort((a, b) => Number(b) - Number(a))
  : [];
---
{showYearHeaders && groupedByYear ? (
  years.map((year) => (
    <>
      <h2 class="year-header">{year}</h2>
      <ul class="entries">
        {groupedByYear[year].map((post) => (
          <li>
            <a href={entryHref(post)} class="entry-link">
              <time datetime={post.data.date.toISOString()} class="entry-date">{fmtDate(post.data.date)}</time>
              <span class="entry-title">{post.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </>
  ))
) : (
  <ul class="entries">
    {entries.map((post) => (
      <li>
        <a href={entryHref(post)} class="entry-link">
          <time datetime={post.data.date.toISOString()} class="entry-date">{fmtDateWithYear(post.data.date)}</time>
          <span class="entry-title">{post.data.title}</span>
        </a>
      </li>
    ))}
  </ul>
)}
